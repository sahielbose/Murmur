# ─────────────────────────────────────────────────────────────────────────────
# Murmur — environment template
#
# Copy this file to `apps/web/.env.local` (and `.env` at the repo root for the
# db/jobs scripts) and fill in values as needed.
#
#   • Phases 1–17 run ENTIRELY on mock/local providers and need NO secrets.
#     The defaults below are enough to build and run the whole product locally.
#   • Phases 18–20 wire real providers. Those keys are grouped at the bottom and
#     are validated by a zod schema (added in Phase 18). If a required key is
#     missing, Murmur falls back to the matching mock adapter so the app still
#     boots.
#
# NEVER commit real secrets. Only `.env.example` is tracked by git.
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Provider selection (mock/local by default — no secrets required) ──────────
# Each provider has a mock/local adapter and a real adapter chosen by these
# switches. Leave as-is for the secret-free build.
AUTH_PROVIDER="mock"            # mock | clerk
STORAGE_PROVIDER="local"        # local | r2
STT_PROVIDER="mock"             # mock | deepgram
LLM_PROVIDER="mock"             # mock | anthropic | openai | gemini
EMBEDDINGS_PROVIDER="mock"      # mock | voyage | openai

# ── Local database (Docker: Postgres + pgvector — see docker-compose.yml) ─────
# Brought online in Phase 4. The docker-compose service uses these credentials.
DATABASE_URL="postgres://murmur:murmur@localhost:5432/murmur"

# ── Local object storage (filesystem) ────────────────────────────────────────
# Where the local-filesystem Storage adapter writes audio in the secret-free
# build (Phase 5). Ignored by git.
STORAGE_LOCAL_DIR="./.data/storage"

# ── Background jobs (Inngest dev server — local, no keys) ─────────────────────
# `npx inngest-cli dev` runs a local durable-workflow server in Phase 6.
INNGEST_DEV="1"

# =============================================================================
# 🔑  REAL PROVIDER KEYS — needed only for Phases 18–20. Leave blank to keep the
#     mock/local adapters. Placeholders only — never put real values here.
# =============================================================================

# Phase 18 — Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Phase 18 — Database (Neon Postgres). Overrides the local DATABASE_URL above.
# DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# Phase 18 — Object storage (Cloudflare R2, S3-compatible)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# Phase 19 — Speech-to-text + diarization (Deepgram)
DEEPGRAM_API_KEY=""

# Phase 19 — LLM (Anthropic Claude; OpenAI / Gemini optional for model choice)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Phase 19 — Embeddings (Voyage, or OpenAI as a fallback)
VOYAGE_API_KEY=""

# Phase 19 — Inngest Cloud (durable jobs in production)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Phase 20 — Billing (Stripe, Pro plan)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Phase 20 — Email (Resend, approval-gated sends only)
RESEND_API_KEY=""

# Phase 20 — Google Calendar (OAuth, approval-gated push)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
