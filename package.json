{
  "name": "murmur",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter @murmur/web dev",
    "build": "pnpm --filter @murmur/web build",
    "start": "pnpm --filter @murmur/web start",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "db:up": "sh scripts/db-up.sh",
    "db:down": "sh scripts/db-down.sh",
    "db:generate": "pnpm --filter @murmur/db db:generate",
    "db:migrate": "pnpm --filter @murmur/db db:migrate",
    "db:seed": "pnpm --filter @murmur/db db:seed",
    "inngest:dev": "npx --yes inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@murmur/ai": "workspace:*",
    "@murmur/db": "workspace:*",
    "@murmur/jobs": "workspace:*",
    "dotenv": "^17.4.2",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,yml,yaml}": "prettier --write --ignore-unknown"
  }
}
